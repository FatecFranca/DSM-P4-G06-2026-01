# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL="postgresql://agrotech:agrotech@postgres:5432/agrotech?schema=public" # Variaveis do docker-compose
DIRECT_URL="postgresql://agrotech:agrotech@postgres:5432/agrotech?schema=public"

# InfluxDB
INFLUX_URL="http://influxdb:8086"
INFLUX_TOKEN="my-super-secret-token"
INFLUX_ORG="agrotech"
INFLUX_BUCKET="agrotech_data"

# Redis
REDIS_URL="redis://redis:6379"

# MQTT Broker
MQTT_URL="mqtt://IPV4_ADDRESS_AQUI:1883" # Substitua pelo IP do seu broker MQTT. Rode ipconfig e encontre o IPV4
MQTT_USERNAME="agrotech"
MQTT_PASSWORD="agrotech_secret"
MQTT_CLIENT_ID="agrotech-backend"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="alerts@agrotech.com"
SMTP_PASS="your-smtp-password"
ALERT_EMAIL_TO="admin@agrotech.com"

# Rate limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX="100"
